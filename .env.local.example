# Backend API origin (server-side + proxy target)
API_URL=http://localhost:8001
# Public site origin (SEO canonical/OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Razorpay PUBLIC key id for web Checkout (W1). Safe to expose; the secret stays
# server-side in the API. Leave blank to keep checkout in dry-run.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
